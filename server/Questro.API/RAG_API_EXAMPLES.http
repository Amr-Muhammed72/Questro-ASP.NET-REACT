### ==========================================
### RAG Integration API Examples
### ==========================================
### Use this file with REST Client extension
### Update YOUR_TOKEN_HERE with actual JWT

@baseUrl = http://localhost:5000
@token = Bearer YOUR_TOKEN_HERE

### ==========================================
### HEALTH CHECKS
### ==========================================

### 1. Check RAG Service Health
GET {{baseUrl}}/api/recommendations/health

### 2. Check if API is running
GET {{baseUrl}}/api/recommendations/health

### ==========================================
### BASIC RECOMMENDATION QUERIES
### ==========================================

### 3. Simple Query - Action Games
POST {{baseUrl}}/api/recommendations/query
Authorization: {{token}}
Content-Type: application/json

{
  "query": "action-packed games with fast-paced combat",
  "k": 5,
  "allow_adult": false
}

### 4. Simple Query - Relaxing Games
POST {{baseUrl}}/api/recommendations/query
Authorization: {{token}}
Content-Type: application/json

{
  "query": "relaxing puzzle games to unwind",
  "k": 5,
  "allow_adult": false
}

### 5. Simple Query - Movies
POST {{baseUrl}}/api/recommendations/query
Authorization: {{token}}
Content-Type: application/json

{
  "query": "superhero movies with great action sequences",
  "k": 5,
  "allow_adult": false
}

### ==========================================
### FILTERED QUERIES
### ==========================================

### 6. Query with Blocked Genres
POST {{baseUrl}}/api/recommendations/query
Authorization: {{token}}
Content-Type: application/json

{
  "query": "open world games",
  "k": 10,
  "allow_adult": false,
  "blocked_genres": ["Horror", "Violent"]
}

### 7. Query with Many Results
POST {{baseUrl}}/api/recommendations/query
Authorization: {{token}}
Content-Type: application/json

{
  "query": "strategy games with deep gameplay",
  "k": 20,
  "allow_adult": false
}

### ==========================================
### PERSONALIZED QUERIES
### ==========================================

### 8. Query with User Profile - Young Adult
POST {{baseUrl}}/api/recommendations/query
Authorization: {{token}}
Content-Type: application/json

{
  "query": "competitive online multiplayer games",
  "k": 10,
  "allow_adult": false,
  "user": {
    "age": 22,
    "gender": "Male",
    "profession": "Student",
    "country": "USA",
    "game_genres_fav": "Action|Shooter|Sports",
    "game_genres_disliked": "Puzzle|Casual",
    "ratings": [
      {
        "item_id": "game_3498",
        "stars": 5
      },
      {
        "item_id": "game_16405",
        "stars": 4
      }
    ]
  }
}

### 9. Query with User Profile - Adult Gamer
POST {{baseUrl}}/api/recommendations/query
Authorization: {{token}}
Content-Type: application/json

{
  "query": "immersive story-driven games",
  "k": 10,
  "allow_adult": true,
  "user": {
    "age": 35,
    "gender": "Female",
    "profession": "Engineer",
    "country": "Canada",
    "movie_genres_fav": "Drama|Sci-Fi|Mystery",
    "game_genres_fav": "RPG|Adventure|Narrative",
    "game_genres_disliked": "Sports|Racing",
    "ratings": [
      {
        "item_id": "game_19487",
        "stars": 5
      }
    ]
  }
}

### 10. Query with User Profile - Movie Enthusiast
POST {{baseUrl}}/api/recommendations/query
Authorization: {{token}}
Content-Type: application/json

{
  "query": "indie films with artistic direction",
  "k": 8,
  "allow_adult": false,
  "user": {
    "age": 28,
    "gender": "Other",
    "profession": "Designer",
    "country": "UK",
    "movie_genres_fav": "Documentary|Drama|Romance",
    "movie_genres_disliked": "Comedy|Horror",
    "ratings": [
      {
        "item_id": "movie_500",
        "stars": 5
      },
      {
        "item_id": "movie_278",
        "stars": 4.5
      }
    ]
  }
}

